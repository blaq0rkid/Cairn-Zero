
# =============================================================================
# CAIRN ZERO - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local for local development
# Copy to .env.production for production deployment
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT MODE
# -----------------------------------------------------------------------------
# Options: "production" | "staging" | "development"
NEXT_PUBLIC_ENVIRONMENT_MODE=production

# Show/hide testing UI elements
# In production, this MUST be false
NEXT_PUBLIC_SHOW_TEST_UI=false

# Enable simulation mode routes
# In production, this MUST be false
NEXT_PUBLIC_ENABLE_SIMULATION=false

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Production Supabase Project
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Staging Supabase Project (separate database)
# NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# -----------------------------------------------------------------------------
# STRIPE CONFIGURATION
# -----------------------------------------------------------------------------
# Production Stripe Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key
STRIPE_SECRET_KEY=sk_live_your_production_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook

# Staging/Test Stripe Keys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
# STRIPE_SECRET_KEY=sk_test_your_test_key
# STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook

# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://mycairnzero.com
NEXT_PUBLIC_STAGING_URL=https://staging.mycairnzero.com

# -----------------------------------------------------------------------------
# SECURITY & ACCESS
# -----------------------------------------------------------------------------
# Staging access password (for /internal/sandbox)
STAGING_ACCESS_PASSWORD=your-secure-staging-password

# Engraver tool access password
ENGRAVER_TOOL_PASSWORD=your-secure-engraver-password

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_PHYSICAL_KEYS=true
NEXT_PUBLIC_ENABLE_GUIDEPOSTS=true
NEXT_PUBLIC_ENABLE_EMAIL_INVITES=true

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=noreply@cairnzero.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Cairn Zero <noreply@cairnzero.com>
